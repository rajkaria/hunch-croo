# CROO Agent Protocol (get a key at https://agent.croo.network — shown once)
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws
CROO_SDK_KEY=croo_sk_...

# Hunch public API (no key needed for read endpoints)
HUNCH_API_URL=https://www.playhunch.xyz

# hedge-quote (Market Desk): deterministic per-order stake cap the plan may
# recommend. The LLM never sizes a hedge — this cap does. Non-custodial, so it
# bounds the plan we hand back, not the desk's own money.
HEDGE_QUOTE_MAX_STAKE_USD=10

# portfolio-hedge (S13): deterministic caps for the basket hedge. MAX_STAKE bounds
# the TOTAL basket premium; MAX_LEG_STAKE bounds any single leg. The LLM never
# sizes the basket — these do. Non-custodial, so they bound the plan, not funds.
PORTFOLIO_HEDGE_MAX_STAKE_USD=50
PORTFOLIO_HEDGE_MAX_LEG_STAKE_USD=10

# Signal-buyer (S8) — the requester side. An agent cannot hire itself, so this
# is a SEPARATE key. Without SIGNAL_BUYER_ENABLED=true the buyer only dry-runs.
CROO_REQUESTER_SDK_KEY=croo_sk_...
SIGNAL_BUYER_ENABLED=false
# JSON array of human-curated counterparties the buyer may pay:
# [{"serviceId":"svc_...","label":"Alpha Terminal","category":"research","maxPriceUsd":1}]
SIGNAL_BUYER_ALLOWLIST=[]
SIGNAL_BUYER_DAILY_CAP_USD=5
SIGNAL_BUYER_MAX_PRICE_USD=1
# SIGNAL_BUYER_PER_SERVICE_CAP_USD=2

# Dashboard "who we hired" feed reads requester orders with this (or a comma list)
# CROO_REQUESTER_KEYS=croo_sk_...

# Hardening (S10) — sensible defaults; override only if needed.
# Transient deliver failures are retried with exponential backoff; anything
# still failing is left paid for the periodic sweep (no stuck escrow).
ORACLE_DELIVER_RETRIES=3
ORACLE_RETRY_BASE_MS=250
ORACLE_SWEEP_INTERVAL_MS=60000
# Set to expose the ops server: JSON status (:PORT/status, :PORT/healthz) AND
# the Prometheus exposition (:PORT/metrics — S12 observability). One port, no
# extra config: point Grafana at :PORT/metrics for throughput, uptime, booked
# revenue, and the live calibration score.
# ORACLE_HEALTH_PORT=8080

# Track-record scorecard (S11) — opt-in. Set a path to enable the forecast
# ledger: delivered forecasts are recorded (append-only, hash-chained), the
# `scorecard` service is served, and a settle sweep scores resolved markets.
# Unset → no recording (the desk behaves exactly as before).
# ORACLE_LEDGER_PATH=./data/track-record.jsonl
ORACLE_SETTLE_INTERVAL_MS=300000
